# Template for config/Makefile.exports, generated by configure.
# Provides configured values as Make variables for inclusion in
# the top-level Makefile.
#

@MODULES_TRUE@LUSTRE_MODULES_MT = modules
@BUILD_LUSTREIOKIT_TRUE@LUSTRE_IOKIT_MT = lustre-iokit
@LDISKFS_ENABLED_TRUE@LUSTRE_LDISKFS_MT = ldiskfs
@BUILT_IN_KO2IBLND_TRUE@LUSTRE_BUILT_IN_KO2IBLND_NT = lnet/klnds/in-kernel-o2iblnd
@EXTERNAL_KO2IBLND_TRUE@LUSTRE_EXTERNAL_KO2IBLND_NT = lnet/klnds/o2iblnd
@HAVE_DEBUG_INFO_BTF_MODULES_TRUE@LUSTRE_EMBED_BTF = yes

CC = @CC@
LINUX_OBJ = @LINUX_OBJ@
LINUXRELEASE = @LINUXRELEASE@
systemdsystemunitdir = @systemdsystemunitdir@

PACKAGE = @PACKAGE@
PACKAGE_TARNAME = @PACKAGE_TARNAME@
VERSION = @VERSION@
RPMBUILD = @RPMBUILD@
RPMBUILD_BINARY_ARGS = @RPMBUILD_BINARY_ARGS@
CONFIG_CACHE_FILE = @CONFIG_CACHE_FILE@

ENABLE_SERVER = @ENABLE_SERVER@
ENABLE_LDISKFS = @ENABLE_LDISKFS@
ENABLE_ZFS = @ENABLE_ZFS@
ENABLE_MULTIPLE_LNDS = @ENABLE_MULTIPLE_LNDS@
ENABLE_GNI = @ENABLE_GNI@
KFILND = @KFILND@
DPKG_EXT_O2IB = @DPKG_EXT_O2IB@
EXT_O2IBPATH = @EXT_O2IBPATH@
DPKG_INT_O2IB = @DPKG_INT_O2IB@
EFALND = @EFALND@
ENABLE_GSS = @ENABLE_GSS@
ENABLE_CRYPTO = @ENABLE_CRYPTO@
ENABLE_PINGER = @ENABLE_PINGER@
ENABLE_CHECKSUM = @ENABLE_CHECKSUM@
ENABLE_FLOCK = @ENABLE_FLOCK@
ENABLE_LRU_RESIZE = @ENABLE_LRU_RESIZE@
ENABLE_MINDF = @ENABLE_MINDF@
ENABLE_FAIL_ALLOC = @ENABLE_FAIL_ALLOC@
ENABLE_INVARIANTS = @ENABLE_INVARIANTS@
ENABLE_LU_REF = @ENABLE_LU_REF@
ENABLE_PGSTAT_TRACK = @ENABLE_PGSTAT_TRACK@
ENABLE_LIBCFS_CDEBUG = @ENABLE_LIBCFS_CDEBUG@
ENABLE_LIBCFS_TRACE = @ENABLE_LIBCFS_TRACE@
ENABLE_LIBCFS_ASSERT = @ENABLE_LIBCFS_ASSERT@
ENABLE_PANIC_DUMPLOG = @ENABLE_PANIC_DUMPLOG@
ENABLE_READLINE = @ENABLE_READLINE@
ENABLE_LIBPTHREAD = @ENABLE_LIBPTHREAD@
ENABLE_BACKOFF = @ENABLE_BACKOFF@
ENABLE_EFENCE = @ENABLE_EFENCE@
ENABLE_COVERAGE = @ENABLE_COVERAGE@
ENABLEO2IB = @ENABLEO2IB@

@MPITESTS_TRUE@ENABLE_MPITESTS = yes
@MPITESTS_FALSE@ENABLE_MPITESTS = no
@TESTS_TRUE@ENABLE_TESTS = yes
@TESTS_FALSE@ENABLE_TESTS = no
@UTILS_TRUE@ENABLE_UTILS = yes
@UTILS_FALSE@ENABLE_UTILS = no
@BUILD_LUSTREIOKIT_TRUE@ENABLE_IOKIT = yes
@BUILD_LUSTREIOKIT_FALSE@ENABLE_IOKIT = no

LUSTRE_CC = $(CC)
LUSTRE_LINUX_OBJ = $(LINUX_OBJ)
LUSTRE_INT_O2IB_SYMBOLS = @INT_O2IB_SYMBOLS@
LUSTRE_EXT_O2IB_SYMBOLS = @EXT_O2IB_SYMBOLS@
LUSTRE_EXTRA_SYMBOLS = @EXTRA_SYMBOLS@

# Build configuration exports
@SERVER_TRUE@export CONFIG_LUSTRE_FS_SERVER := m
@CLIENT_TRUE@export CONFIG_LUSTRE_FS := m
@TESTS_TRUE@export CONFIG_LUSTRE_FS_TESTS := m
@LDISKFS_ENABLED_TRUE@export CONFIG_LUSTRE_FS_LDISKFS := m
@ZFS_ENABLED_TRUE@export CONFIG_LUSTRE_FS_ZFS := m
@GSS_TRUE@export CONFIG_LUSTRE_FS_GSS := m
@GSS_SSK_TRUE@export CONFIG_LUSTRE_FS_GSS_SSK := m
@GSS_KEYRING_TRUE@export CONFIG_LUSTRE_FS_GSS_KEYRING := m
@SPL_ENABLED_TRUE@export CONFIG_LUSTRE_FS_SPL := m
@BUILD_GNILND_TRUE@export CONFIG_LNET_GNILND := m
@BUILT_IN_KO2IBLND_TRUE@export CONFIG_LNET_O2IBLND := m
@BUILD_KFILND_TRUE@export CONFIG_LNET_KFILND := m
@BUILD_EFALND_TRUE@export CONFIG_LNET_EFALND := m

export CONFIG_GCOV_PROFILE_LUSTRE := @ENABLE_COVERAGE@
export CONFIG_GCOV_PROFILE_LNET := @ENABLE_COVERAGE@
export LUSTRE := @LUSTRE@
export LINUX := @LINUX@
export ABS_TOP_BUILDDIR := @abs_top_builddir@
export GDS_PATH := @GDS_PATH@
export CUDA_PATH := @CUDA_PATH@
export EFA_INCLUDE_PATH := @EFA_INCLUDE_PATH@
export KMOD_WERROR_FLAG := @KMOD_WERROR_FLAG@
export KFICPPFLAGS := @KFICPPFLAGS@
export GNICPPFLAGS := @GNICPPFLAGS@
export EXTRA_OFED_CONFIG := @EXTRA_OFED_CONFIG@
export EXTRA_OFED_INCLUDE := @EXTRA_OFED_INCLUDE@
export EXT_O2IB_VER := @EXT_O2IB_VER@
export ZFS := @ZFS@
export ZFS_OBJ := @ZFS_OBJ@
export SPL := @SPL@
export SPL_OBJ := @SPL_OBJ@
